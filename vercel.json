{
  "version": 2,
  "builds": [
    {
      "src": "biblioteca.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.{svg,webp,png,jpg,jpeg}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "biblioteca.py"
    },
    {
      "src": "/",
      "dest": "/bibliotecaa.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
